<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<ScrollPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.pos.controller.DebtController"
            fitToWidth="true"
            stylesheets="@css/menu.css"
            styleClass="debt-scroll">

    <VBox spacing="24" styleClass="page-root">
        <padding><Insets top="32" right="32" bottom="32" left="32"/></padding>

        <VBox spacing="4">
            <Label text="Kelola Hutang Piutang" styleClass="page-header-title"/>
            <Label text="Catat dan pantau hutang serta piutang" styleClass="page-header-subtitle"/>
        </VBox>

        <FlowPane hgap="16" vgap="16" prefWrapLength="1200" styleClass="debt-flow">
            <HBox minWidth="320" prefWidth="520" HBox.hgrow="ALWAYS" alignment="CENTER_LEFT" spacing="20"
                  styleClass="debt-summary-hutang">
                <padding><Insets top="22" right="24" bottom="22" left="24"/></padding>

                <VBox spacing="8" HBox.hgrow="ALWAYS">
                    <Label text="Total Hutang Belum Lunas"
                           styleClass="debt-summary-title-hutang"/>
                    <Label fx:id="lblTotalHutang" text="Rp 0"
                           styleClass="debt-summary-value-hutang"/>
                    <Label fx:id="lblCountHutang" text="0 item belum lunas"
                           styleClass="debt-summary-caption-hutang"/>
                </VBox>

                <Button text="+ Tambah Hutang"
                        onAction="#handleTambahHutang"
                        styleClass="debt-action-hutang"/>
            </HBox>

            <HBox minWidth="320" prefWidth="520" HBox.hgrow="ALWAYS" alignment="CENTER_LEFT" spacing="20"
                  styleClass="debt-summary-piutang">
                <padding><Insets top="22" right="24" bottom="22" left="24"/></padding>

                <VBox spacing="8" HBox.hgrow="ALWAYS">
                    <Label text="Total Piutang Belum Lunas"
                           styleClass="debt-summary-title-piutang"/>
                    <Label fx:id="lblTotalPiutang" text="Rp 0"
                           styleClass="debt-summary-value-piutang"/>
                    <Label fx:id="lblCountPiutang" text="0 item belum lunas"
                           styleClass="debt-summary-caption-piutang"/>
                </VBox>

                <Button text="+ Tambah Piutang"
                        onAction="#handleTambahPiutang"
                        styleClass="debt-action-piutang"/>
            </HBox>
        </FlowPane>

        <HBox styleClass="tab-group" spacing="0">
            <padding><Insets top="4" right="4" bottom="4" left="4"/></padding>

            <Button fx:id="btnTabHutang" text="Hutang (0)"
                    onAction="#openTabHutang"
                    HBox.hgrow="ALWAYS"
                    maxWidth="Infinity"
                    styleClass="tab-button-active"/>

            <Button fx:id="btnTabPiutang" text="Piutang (0)"
                    onAction="#openTabPiutang"
                    HBox.hgrow="ALWAYS"
                    maxWidth="Infinity"
                    styleClass="tab-button"/>
        </HBox>

        <VBox VBox.vgrow="ALWAYS" styleClass="debt-section-card">
            <padding><Insets top="24" right="24" bottom="24" left="24"/></padding>

            <Label fx:id="lblSectionTitle" text="Daftar Hutang" styleClass="debt-item-title">
                <VBox.margin><Insets bottom="18"/></VBox.margin>
            </Label>

            <ScrollPane fx:id="scrollDaftar" fitToWidth="true" VBox.vgrow="ALWAYS"
                        styleClass="debt-scroll">
                <VBox fx:id="containerDaftar" spacing="0">
                    <padding><Insets right="2"/></padding>
                </VBox>
            </ScrollPane>
        </VBox>
    </VBox>
</ScrollPane>
