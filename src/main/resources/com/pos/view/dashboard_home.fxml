<?xml version="1.0" encoding="UTF-8"?>
<?import java.lang.String?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.SVGPath?>

<ScrollPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.pos.controller.DashboardHomeController"
            fitToWidth="true"
            styleClass="dashboard-scroll">

    <VBox spacing="24" styleClass="dashboard-page">
        <padding><Insets top="32" right="32" bottom="32" left="32"/></padding>

        <VBox spacing="4">
            <Label text="Dashboard" styleClass="dashboard-section-title"/>
            <Label text="Ringkasan data bisnis Anda" styleClass="dashboard-section-subtitle"/>
        </VBox>

        <FlowPane hgap="16" vgap="16" prefWrapLength="1200" styleClass="metric-grid">
            <VBox minWidth="240" prefWidth="260" maxWidth="1.0E9" spacing="12">
                <styleClass>
                    <String fx:value="metric-card"/>
                    <String fx:value="metric-card-green"/>
                </styleClass>
                <padding><Insets top="20" right="20" bottom="20" left="20"/></padding>
                <HBox alignment="TOP_LEFT" spacing="10">
                    <StackPane>
                        <styleClass>
                            <String fx:value="metric-icon-shell"/>
                            <String fx:value="metric-icon-shell-green"/>
                        </styleClass>
                        <SVGPath content="M4 16 L10 10 L14 14 L21 7 M15 7 H21 V13"
                                 styleClass="metric-svg-green"/>
                    </StackPane>
                </HBox>
                <Label text="Total Penjualan" styleClass="metric-label"/>
                <Label fx:id="lblTotalPenjualan" text="Rp 0" styleClass="metric-value"/>
            </VBox>

            <VBox minWidth="240" prefWidth="260" maxWidth="1.0E9" spacing="12">
                <styleClass>
                    <String fx:value="metric-card"/>
                    <String fx:value="metric-card-blue"/>
                </styleClass>
                <padding><Insets top="20" right="20" bottom="20" left="20"/></padding>
                <HBox alignment="TOP_LEFT" spacing="10">
                    <StackPane>
                        <styleClass>
                            <String fx:value="metric-icon-shell"/>
                            <String fx:value="metric-icon-shell-blue"/>
                        </styleClass>
                        <SVGPath content="M7 3 H17 L21 7 V21 L18 19 L15 21 L12 19 L9 21 L6 19 L3 21 V7 Z M8 8 H16 M8 12 H16 M8 16 H13"
                                 styleClass="metric-svg-blue"/>
                    </StackPane>
                </HBox>
                <Label text="Jumlah Transaksi" styleClass="metric-label"/>
                <Label fx:id="lblJumlahTransaksi" text="0" styleClass="metric-value"/>
                <Label text="Transaksi" styleClass="metric-caption"/>
            </VBox>

            <VBox minWidth="240" prefWidth="260" maxWidth="1.0E9" spacing="12">
                <styleClass>
                    <String fx:value="metric-card"/>
                    <String fx:value="metric-card-red"/>
                </styleClass>
                <padding><Insets top="20" right="20" bottom="20" left="20"/></padding>
                <HBox alignment="TOP_LEFT" spacing="10">
                    <StackPane>
                        <styleClass>
                            <String fx:value="metric-icon-shell"/>
                            <String fx:value="metric-icon-shell-red"/>
                        </styleClass>
                        <SVGPath content="M4 7 H20 V17 H4 Z M4 10 H20 M16 14 H19 M7 14 H11"
                                 styleClass="metric-svg-red"/>
                    </StackPane>
                </HBox>
                <Label text="Hutang Belum Lunas" styleClass="metric-label"/>
                <Label fx:id="lblHutang" text="Rp 0">
                    <styleClass>
                        <String fx:value="metric-value"/>
                        <String fx:value="metric-value-red"/>
                    </styleClass>
                </Label>
            </VBox>

            <VBox minWidth="240" prefWidth="260" maxWidth="1.0E9" spacing="12">
                <styleClass>
                    <String fx:value="metric-card"/>
                    <String fx:value="metric-card-orange"/>
                </styleClass>
                <padding><Insets top="20" right="20" bottom="20" left="20"/></padding>
                <HBox alignment="TOP_LEFT" spacing="10">
                    <StackPane>
                        <styleClass>
                            <String fx:value="metric-icon-shell"/>
                            <String fx:value="metric-icon-shell-orange"/>
                        </styleClass>
                        <SVGPath content="M4 7 H20 V17 H4 Z M4 10 H20 M16 14 H19 M7 14 H12"
                                 styleClass="metric-svg-orange"/>
                    </StackPane>
                </HBox>
                <Label text="Piutang Belum Lunas" styleClass="metric-label"/>
                <Label fx:id="lblPiutang" text="Rp 0">
                    <styleClass>
                        <String fx:value="metric-value"/>
                        <String fx:value="metric-value-orange"/>
                    </styleClass>
                </Label>
            </VBox>
        </FlowPane>

        <HBox spacing="20" alignment="TOP_LEFT">
            <VBox HBox.hgrow="ALWAYS" minWidth="360" spacing="14">
                <styleClass>
                    <String fx:value="panel-card"/>
                    <String fx:value="panel-warning-card"/>
                </styleClass>
                <padding><Insets top="20" right="20" bottom="20" left="20"/></padding>
                <HBox alignment="CENTER_LEFT" spacing="12">
                    <Label text="Peringatan Stok Menipis" styleClass="panel-warning-title"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Button text="Restok Menu"
                            onAction="#handleOpenStock">
                        <styleClass>
                            <String fx:value="panel-link-button"/>
                            <String fx:value="panel-link-button-warning"/>
                        </styleClass>
                    </Button>
                    <StackPane>
                        <styleClass>
                            <String fx:value="panel-top-icon"/>
                            <String fx:value="panel-top-icon-warning"/>
                        </styleClass>
                        <SVGPath content="M12 4 L21 20 H3 Z M12 9 V14 M12 17 H12.01"
                                 styleClass="panel-svg-warning"/>
                    </StackPane>
                </HBox>
                <VBox fx:id="containerStokWarning" spacing="12" VBox.vgrow="ALWAYS"/>
            </VBox>

            <VBox HBox.hgrow="ALWAYS" minWidth="420" spacing="14">
                <styleClass>
                    <String fx:value="panel-card"/>
                    <String fx:value="panel-transaction-card"/>
                </styleClass>
                <padding><Insets top="20" right="20" bottom="20" left="20"/></padding>
                <HBox alignment="CENTER_LEFT" spacing="12">
                    <Label text="Transaksi Terbaru" styleClass="panel-title"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Button text="Lihat Semua"
                            onAction="#handleOpenTransaksi">
                        <styleClass>
                            <String fx:value="panel-link-button"/>
                            <String fx:value="panel-link-button-transaction"/>
                        </styleClass>
                    </Button>
                    <StackPane>
                        <styleClass>
                            <String fx:value="panel-top-icon"/>
                            <String fx:value="panel-top-icon-transaction"/>
                        </styleClass>
                        <SVGPath content="M7 3 H17 L21 7 V21 L18 19 L15 21 L12 19 L9 21 L6 19 L3 21 V7 Z M8 9 H16 M8 13 H16 M8 17 H13"
                                 styleClass="panel-svg-transaction"/>
                    </StackPane>
                </HBox>
                <VBox fx:id="containerTransaksiBaru" spacing="12" VBox.vgrow="ALWAYS"/>
            </VBox>
        </HBox>
    </VBox>
</ScrollPane>
