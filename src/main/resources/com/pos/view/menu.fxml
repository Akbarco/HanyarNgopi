<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.pos.controller.MenuController"
      stylesheets="@css/menu.css"
      spacing="24"
      styleClass="page-root">

    <padding><Insets top="32" right="32" bottom="32" left="32"/></padding>

    <HBox alignment="CENTER_LEFT" styleClass="page-shell">
        <VBox HBox.hgrow="ALWAYS" spacing="4">
            <Label text="Kelola Menu" styleClass="page-header-title"/>
            <Label text="Tambah menu aktif, arsipkan yang sudah tidak dijual, dan aktifkan kembali kapan saja" styleClass="page-header-subtitle"/>
        </VBox>

        <Button text="+ Tambah Menu"
                onAction="#handleTambahMenu"
                styleClass="action-button"/>
    </HBox>

    <VBox VBox.vgrow="ALWAYS" styleClass="surface-card">
        <padding><Insets top="20" right="20" bottom="20" left="20"/></padding>

        <HBox alignment="CENTER_LEFT" spacing="18" styleClass="menu-table-toolbar">
            <VBox.margin><Insets bottom="12"/></VBox.margin>
            <VBox spacing="3" HBox.hgrow="ALWAYS">
                <Label fx:id="lblTableTitle" text="Daftar Menu Aktif" styleClass="surface-card-header"/>
                <Label text="Kelola menu yang tampil di operasional harian" styleClass="surface-card-caption"/>
            </VBox>

            <HBox styleClass="menu-segmented-control" spacing="4">
                <padding><Insets top="4" right="4" bottom="4" left="4"/></padding>

                <Button fx:id="btnTabAktif"
                        text="Aktif"
                        onAction="#openTabAktif"
                        styleClass="menu-segment-active"/>

                <Button fx:id="btnTabArsip"
                        text="Diarsipkan"
                        onAction="#openTabArsip"
                        styleClass="menu-segment"/>
            </HBox>
        </HBox>

        <VBox VBox.vgrow="ALWAYS" styleClass="table-wrapper">
            <TableView fx:id="tableMenu" VBox.vgrow="ALWAYS">
                <columns>
                    <TableColumn fx:id="colNama" text="Nama Menu"/>
                    <TableColumn fx:id="colKategori" text="Kategori"/>
                    <TableColumn fx:id="colHarga" text="Harga"/>
                    <TableColumn fx:id="colAksi" text="Aksi"/>
                </columns>
                <columnResizePolicy>
                    <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                </columnResizePolicy>
                <placeholder>
                    <Label fx:id="lblPlaceholder"
                           text="Belum ada menu aktif"
                           styleClass="placeholder-text"/>
                </placeholder>
            </TableView>
        </VBox>
    </VBox>
</VBox>
