<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.pos.controller.MenuController"
      stylesheets="@css/menu.css"
      spacing="24"
      style="-fx-background-color: #F1F5F9;">

    <padding><Insets top="32" right="32" bottom="32" left="32"/></padding>

    <!-- Header -->
    <HBox alignment="CENTER_LEFT">
        <VBox HBox.hgrow="ALWAYS" spacing="4">
            <Label text="Kelola Menu"
                   style="-fx-font-size: 28; -fx-font-weight: bold; -fx-text-fill: #111827;"/>
            <Label text="Tambah, edit, dan hapus menu"
                   style="-fx-font-size: 13; -fx-text-fill: #6B7280;"/>
        </VBox>

        <Button text="+ Tambah Menu" onAction="#handleTambahMenu"
                style="-fx-background-color: #111827; -fx-text-fill: white;
                       -fx-font-weight: bold; -fx-font-size: 13;
                       -fx-background-radius: 10; -fx-cursor: hand;
                       -fx-pref-height: 44; -fx-padding: 0 24 0 24;"/>
    </HBox>

    <!-- Card -->
    <VBox VBox.vgrow="ALWAYS"
          style="-fx-background-color: white; -fx-background-radius: 16;
                 -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.07), 16, 0, 0, 4);">

        <padding><Insets top="20" right="20" bottom="20" left="20"/></padding>

        <!-- Card Header -->
        <HBox alignment="CENTER_LEFT">
            <VBox.margin><Insets bottom="12"/></VBox.margin>
            <Label text="Daftar Menu" HBox.hgrow="ALWAYS"
                   style="-fx-font-size: 16; -fx-font-weight: bold; -fx-text-fill: #111827;"/>
        </HBox>

        <!-- 🔥 Wrapper (INI YANG BIKIN BAGUS) -->
        <VBox styleClass="table-wrapper" VBox.vgrow="ALWAYS">

            <TableView fx:id="tableMenu" VBox.vgrow="ALWAYS">
                <columns>
                    <TableColumn fx:id="colNama" text="Nama Menu"/>
                    <TableColumn fx:id="colKategori" text="Kategori"/>
                    <TableColumn fx:id="colHarga" text="Harga"/>
                    <TableColumn fx:id="colAksi" text="Aksi"/>
                </columns>

                <columnResizePolicy>
                    <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                </columnResizePolicy>

                <placeholder>
                    <Label text="Belum ada data menu"
                           style="-fx-text-fill: #9CA3AF; -fx-font-size: 13;"/>
                </placeholder>
            </TableView>

        </VBox>
    </VBox>
</VBox>