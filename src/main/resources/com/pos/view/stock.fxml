<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.pos.controller.StockController"
      stylesheets="@css/menu.css"
      spacing="24"
      style="-fx-background-color: #F1F5F9;">
    <padding><Insets top="32" right="32" bottom="32" left="32"/></padding>

    <!-- Header -->
    <HBox alignment="CENTER_LEFT">
        <VBox HBox.hgrow="ALWAYS" spacing="4">
            <Label text="Kelola Stok"
                   style="-fx-font-size: 28; -fx-font-weight: bold;
                          -fx-text-fill: #111827;"/>
            <Label text="Pantau dan kelola stok bahan baku"
                   style="-fx-font-size: 13; -fx-text-fill: #6B7280;"/>
        </VBox>
        <Button text="+ Tambah Stok" onAction="#handleTambahStock"
                style="-fx-background-color: #111827; -fx-text-fill: white;
                       -fx-font-weight: bold; -fx-font-size: 13;
                       -fx-background-radius: 10; -fx-cursor: hand;
                       -fx-pref-height: 44; -fx-padding: 0 24 0 24;"/>
    </HBox>

    <!-- Table Card -->
    <VBox VBox.vgrow="ALWAYS"
          style="-fx-background-color: white; -fx-background-radius: 16;
                 -fx-effect: dropshadow(gaussian,rgba(0,0,0,0.07),16,0,0,4);">
        <padding><Insets top="24" right="24" bottom="24" left="24"/></padding>

        <Label text="Daftar Stok"
               style="-fx-font-size: 16; -fx-font-weight: bold; -fx-text-fill: #111827;">
            <VBox.margin><Insets bottom="16"/></VBox.margin>
        </Label>

        <TableView fx:id="tableStock" VBox.vgrow="ALWAYS"
                   style="-fx-background-color: transparent;
                          -fx-border-color: transparent;">
            <columns>
                <TableColumn fx:id="colNama" text="Nama Barang" prefWidth="220"/>
                <TableColumn fx:id="colJumlah" text="Jumlah" prefWidth="100"/>
                <TableColumn fx:id="colSatuan" text="Satuan" prefWidth="100"/>
                <TableColumn fx:id="colMinimum" text="Stok Minimum" prefWidth="130"/>
                <TableColumn fx:id="colStatus" text="Status" prefWidth="150"/>
                <TableColumn fx:id="colAksi" text="Aksi" prefWidth="180"/>
            </columns>
            <columnResizePolicy>
                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
            </columnResizePolicy>
            <placeholder>
                <Label text="Belum ada data stok"
                       style="-fx-text-fill: #9CA3AF; -fx-font-size: 13;"/>
            </placeholder>
        </TableView>
    </VBox>
</VBox>