<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.pos.controller.StockController"
      stylesheets="@css/menu.css"
      spacing="24"
      styleClass="page-root">

    <padding><Insets top="32" right="32" bottom="32" left="32"/></padding>

    <HBox alignment="CENTER_LEFT" styleClass="page-shell">
        <VBox HBox.hgrow="ALWAYS" spacing="4">
            <Label text="Kelola Stok" styleClass="page-header-title"/>
            <Label text="Pantau dan kelola stok bahan baku" styleClass="page-header-subtitle"/>
        </VBox>

        <Button text="+ Tambah Stok"
                onAction="#handleTambahStock"
                styleClass="action-button"/>
    </HBox>

    <VBox VBox.vgrow="ALWAYS" styleClass="surface-card">
        <padding><Insets top="24" right="24" bottom="24" left="24"/></padding>

        <Label text="Daftar Stok" styleClass="surface-card-header">
            <VBox.margin><Insets bottom="16"/></VBox.margin>
        </Label>

        <TableView fx:id="tableStock" VBox.vgrow="ALWAYS">
            <columns>
                <TableColumn fx:id="colNama" text="Nama Barang"/>
                <TableColumn fx:id="colSatuan" text="Satuan"/>
                <TableColumn fx:id="colJumlah" text="Jumlah"/>
                <TableColumn fx:id="colMinimum" text="Stok Minimum"/>
                <TableColumn fx:id="colStatus" text="Status"/>
                <TableColumn fx:id="colAksi" text="Aksi"/>
            </columns>
            <columnResizePolicy>
                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
            </columnResizePolicy>
            <placeholder>
                <Label text="Belum ada data stok"
                       styleClass="placeholder-text"/>
            </placeholder>
        </TableView>
    </VBox>
</VBox>
