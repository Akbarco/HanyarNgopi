<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<?import java.awt.Image?>
<?import javafx.scene.image.ImageView?>
<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.pos.controller.DashboardController"
            stylesheets="@css/dashboard.css"
            prefWidth="1280" prefHeight="800">

    <left>
        <VBox prefWidth="260"
              style="-fx-background-color: white;
                     -fx-border-color: transparent #E5E7EB transparent transparent;
                     -fx-border-width: 0 1 0 0;">
            <padding><Insets top="24" right="16" bottom="24" left="16"/></padding>

            <!-- Logo -->
            <HBox spacing="12" alignment="CENTER_LEFT">
                <padding><Insets bottom="8"/></padding>
                <ImageView fx:id="logoImage"
                           fitWidth="44"
                           fitHeight="44"
                           preserveRatio="true"/>
                <VBox spacing="2">
                    <Label text="HanyarNgopi"
                           style="-fx-text-fill: #111827; -fx-font-size: 15;
                      -fx-font-weight: bold;"/>
                    <Label text="Sistem Manajemen"
                           style="-fx-text-fill: #6B7280; -fx-font-size: 11;"/>
                </VBox>
            </HBox>

            <!-- User info -->
            <VBox style="-fx-background-color: #EEF2FF; -fx-background-radius: 12;"
                  spacing="3">
                <padding><Insets top="14" right="14" bottom="14" left="14"/></padding>
                <VBox.margin><Insets top="16" bottom="24"/></VBox.margin>
                <Label text="Login sebagai:"
                       style="-fx-text-fill: #6B7280; -fx-font-size: 11;"/>
                <Label fx:id="lblUsername" text="Administrator"
                       style="-fx-text-fill: #4F46E5; -fx-font-size: 15;
                              -fx-font-weight: bold;"/>
            </VBox>

            <!-- Menu label -->
            <Label text="MENU UTAMA"
                   style="-fx-text-fill: #9CA3AF; -fx-font-size: 10;
                          -fx-font-weight: bold; -fx-padding: 0 0 0 4;">
                <VBox.margin><Insets bottom="6"/></VBox.margin>
            </Label>

            <!-- Nav buttons -->
            <Button fx:id="btnDashboard" text="  📊  Dashboard"
                    onAction="#openDashboardHome"
                    maxWidth="Infinity" styleClass="nav-btn-active">
                <VBox.margin><Insets bottom="2"/></VBox.margin>
            </Button>
            <Button fx:id="btnMenu" text="  🍽  Menu"
                    onAction="#openMenu"
                    maxWidth="Infinity" styleClass="nav-btn">
                <VBox.margin><Insets bottom="2"/></VBox.margin>
            </Button>
            <Button fx:id="btnStok" text="  📦  Stok"
                    onAction="#openStock"
                    maxWidth="Infinity" styleClass="nav-btn">
                <VBox.margin><Insets bottom="2"/></VBox.margin>
            </Button>
            <Button fx:id="btnTransaksi" text="  🧾  Transaksi"
                    onAction="#openTransaksi"
                    maxWidth="Infinity" styleClass="nav-btn">
                <VBox.margin><Insets bottom="2"/></VBox.margin>
            </Button>
            <Button fx:id="btnHutang" text="  💳  Hutang"
                    onAction="#openHutang"
                    maxWidth="Infinity" styleClass="nav-btn">
                <VBox.margin><Insets bottom="2"/></VBox.margin>
            </Button>
            <Button fx:id="btnLaporan" text="  📄  Laporan"
                    onAction="#openLaporan"
                    maxWidth="Infinity" styleClass="nav-btn">
                <VBox.margin><Insets bottom="2"/></VBox.margin>
            </Button>

            <VBox VBox.vgrow="ALWAYS"/>

            <Label text="© 2026 Warung App"
                   style="-fx-text-fill: #D1D5DB; -fx-font-size: 10;">
                <VBox.margin><Insets bottom="10"/></VBox.margin>
            </Label>

            <Button text="  →  Keluar" onAction="#handleLogout"
                    maxWidth="Infinity"
                    style="-fx-background-color: #FEF2F2;
                           -fx-text-fill: #EF4444;
                           -fx-font-weight: bold; -fx-alignment: CENTER-LEFT;
                           -fx-cursor: hand; -fx-pref-height: 42;
                           -fx-background-radius: 8;"/>
        </VBox>
    </left>

    <center>
        <StackPane fx:id="contentArea"
                   style="-fx-background-color: #F1F5F9;"/>
    </center>

</BorderPane>